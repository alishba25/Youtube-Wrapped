# Copy this file to .env and fill in real values. Never commit .env itself.

# From Google Cloud Console > APIs & Services > Credentials > OAuth client ID
GOOGLE_CLIENT_ID= 
GOOGLE_CLIENT_SECRET= 

# Must exactly match a redirect URI registered on that OAuth client
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# From Google Cloud Console > APIs & Services > Credentials > API key
# (used for public video-metadata lookups on the Takeout path)
YOUTUBE_API_KEY= 

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Where the frontend is served from - used for post-login redirects
FRONTEND_URL=http://localhost:8000

DEBUG=true
